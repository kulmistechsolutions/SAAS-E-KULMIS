# ─────────────────────────────────────────────────────────────
# eKulmis — Environment (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
# Root domain for tenant subdomains (e.g. iskuul1.ekulmis.local)
APP_ROOT_DOMAIN=ekulmis.local

# ── PostgreSQL (via PgBouncer in prod; direct locally) ──
POSTGRES_USER=ekulmis
POSTGRES_PASSWORD=ekulmis_dev_password
POSTGRES_DB=ekulmis
# Prisma runtime connection (through PgBouncer: port 6432)
DATABASE_URL=postgresql://ekulmis:ekulmis_dev_password@localhost:5432/ekulmis?schema=public
# Direct connection for migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://ekulmis:ekulmis_dev_password@localhost:5432/ekulmis?schema=public

# ── Redis (cache + BullMQ + Socket.IO adapter) ──
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible object storage) ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=ekulmis
MINIO_ROOT_PASSWORD=ekulmis_dev_password
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_IMPORTS=imports
MINIO_BUCKET_BACKUPS=backups

# ── Auth (JWT + refresh) ──
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── SMTP (email) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="eKulmis <no-reply@ekulmis.local>"

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000
