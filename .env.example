# ─────────────────────────────────────────────────────────────
# eKulmis — Environment (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=4000
# Max JSON body size (student photo uploads use base64 in JSON; default 5mb)
API_JSON_BODY_LIMIT=5mb
WEB_PORT=3000
# Root domain for tenant subdomains (e.g. iskuul1.ekulmis.local)
APP_ROOT_DOMAIN=ekulmis.local

# ── PostgreSQL (via PgBouncer in prod; direct locally) ──
POSTGRES_USER=ekulmis
POSTGRES_PASSWORD=ekulmis_dev_password
POSTGRES_DB=ekulmis
# Prisma runtime connection (through PgBouncer: port 6432)
DATABASE_URL=postgresql://ekulmis:ekulmis_dev_password@localhost:5432/ekulmis?schema=public
# Direct connection for migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://ekulmis:ekulmis_dev_password@localhost:5432/ekulmis?schema=public

# ── Redis (BullMQ job queues) ──
# Set to true when Redis is running; false disables BullMQ (no ECONNREFUSED spam)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Supabase Storage (student photos, documents) ──
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role key (server-only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=ekulmis
# Comma-separated buckets that use public URLs (others get signed URLs)
SUPABASE_STORAGE_PUBLIC_BUCKETS=ekulmis
# auto = Supabase → MinIO → local disk (dev fallback)
STORAGE_BACKEND=auto

# ── MinIO (optional local S3; used only if Supabase is not configured) ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=ekulmis
MINIO_ROOT_PASSWORD=ekulmis_dev_password
MINIO_BUCKET=ekulmis
# LOCAL_STORAGE_PATH=apps/api/.uploads
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_IMPORTS=imports
MINIO_BUCKET_BACKUPS=backups

# ── Auth (JWT + refresh) ──
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── SMTP (email) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="eKulmis <no-reply@ekulmis.local>"

# ── Hormuud SMS (optional env fallback; prefer Platform Admin → SMS config) ──
# HORMUUD_SMS_BASE_URL=https://smsapi.hormuud.com
# HORMUUD_SMS_USERNAME=
# HORMUUD_SMS_PASSWORD=

 ── Hormuud WaafiPay (optional env seed; prefer Platform → Waafi Payments) ──
# Docs: https://docs.waafipay.com/
# WAAFI_BASE_URL=https://sandbox.waafipay.net/asm
# WAAFI_MERCHANT_UID=
# WAAFI_API_USER_ID=
# WAAFI_API_KEY=
# WAAFI_STORE_ID=
# WAAFI_HPP_KEY=
# Public HTTPS API origin for HPP callbacks (no trailing slash)
# WAAFI_CALLBACK_BASE_URL=https://api.yourdomain.com

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000
# Preview mode (no API): school ERP uses NEXT_PUBLIC_PREVIEW_AUTH=true
# Platform Super Admin should use real API login (superadmin / super123).
NEXT_PUBLIC_PREVIEW_PLATFORM_AUTH=false
NEXT_PUBLIC_APP_ROOT_DOMAIN=ekulmis.local
