// eKulmis — Prisma schema.
// Multi-tenant SaaS: EVERY domain model carries `schoolId` (tenant key).
// PostgreSQL Row-Level Security (added in Phase 0.5 migration SQL) enforces
// isolation; all uniqueness is scoped per school.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// The tenant. One row per school. Root of all tenant-scoped data.
model School {
  id        String       @id @default(cuid())
  /// Subdomain used for tenant resolution, e.g. "iskuul1" -> iskuul1.app.com
  subdomain String       @unique
  name      String
  status    SchoolStatus @default(ACTIVE)

  // ── Settings & branding (Module 16 / §7) ──
  motto                String?
  address              String?
  phone                String?
  email                String?
  website              String?
  principalName        String?
  logoKey              String? // MinIO object key (uploaded separately)
  stampKey             String?
  currency             String  @default("USD")
  timezone             String  @default("UTC")
  language             String  @default("en")
  /// "LEFT" (logo beside name) or "CENTERED" (logo above name) on every printed document.
  documentHeaderLayout String  @default("LEFT")
  receiptHeader        String?
  receiptFooter        String?
  payslipHeader        String?
  payslipFooter        String?
  expenseHeader        String?
  expenseFooter        String?
  studentHeader        String?
  studentFooter        String?
  teacherHeader        String?
  teacherFooter        String?
  parentHeader         String?
  parentFooter         String?
  reportHeader         String?
  reportFooter         String?
  resultFooter         String?

  // ── ID prefixes (auto-generated IDs derive from these) ──
  studentPrefix     String @default("STD")
  teacherPrefix     String @default("TCH")
  parentPrefix      String @default("PAR")
  receiptPrefix     String @default("RCP")
  invoicePrefix     String @default("INV")
  certificatePrefix String @default("CRT")

  /// Free-trial deadline set when Super Admin creates the school. The school
  /// works normally until this passes; after it, sign-in is blocked until a
  /// subscription is assigned. Null = no trial was granted.
  trialEndsAt DateTime?

  /// Hormuud sender ID shown to recipients (defaults to school name when empty).
  smsSenderName String?
  smsEnabled    Boolean @default(true)

  // ── Fee billing (Module 7 dual mode) ──
  billingMode          BillingMode @default(MONTHLY)
  feeAcademicMonths    Int         @default(10)
  feeBillingStartMonth Int         @default(9)
  feeBillingEndMonth   Int         @default(6)
  feeAllowPartial      Boolean     @default(true)
  feeAllowAdvance      Boolean     @default(true)
  feeCarryForward      Boolean     @default(true)
  feeMonthSetupDay     Int         @default(25)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  academicYears      AcademicYear[]
  subjects           Subject[]
  smsPurchases       SmsPurchase[]
  smsMessages        SmsMessage[]
  smsTemplates       SmsTemplate[]
  smsCampaigns       SmsCampaign[]
  smsTransactions    SmsTransaction[]
  smsPaymentOrders   SmsPaymentOrder[]
  smsGateway         SchoolSmsGateway?
  smsGatewayLicenses SmsGatewayLicense[]

  @@map("schools")
}

/// Academic year (Module 13). At most one active per school (partial unique).
model AcademicYear {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school        School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes       Class[]
  assignments   TeacherAssignment[]
  classSubjects ClassSubject[]
  examGroups    ExamGroup[]
  exams         Exam[]
  quizzes       Quiz[]
  feeSetups     AcademicYearFeeSetup[]
  feeCharges    FeeCharge[]
  extraFees     ExtraFee[]
  shifts        SchoolShift[]
  subjectLoads  SubjectLoad[]
  timetables    Timetable[]
  subjectPrefs  SubjectTimePreference[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_years")
}

/// A grade within an academic year. Has many independent Sections.
model Class {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  orderIndex     Int          @default(0)
  hasSections    Boolean      @default(false)
  notes          String?
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  academicYear     AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sections         Section[]
  students         Student[]
  assignments      TeacherAssignment[]
  classSubjects    ClassSubject[]
  exams            Exam[]
  quizzes          Quiz[]
  libraryDocuments LibraryDocument[]
  extraFeeAmounts  ExtraFeeClassAmount[]
  subjectLoads     SubjectLoad[]
  timetableEntries TimetableEntry[]
  subjectPrefs     SubjectTimePreference[]
  /// Which part of the day this class attends. A section may override it.
  shift            SchoolShift?            @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  shiftId          String?

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@map("classes")
}

/// An independent classroom within a Class (§10). Never shares students/marks.
model Section {
  id        String       @id @default(cuid())
  schoolId  String
  classId   String
  name      String
  status    EntityStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  class            Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  students         Student[]
  assignments      TeacherAssignment[]
  classSubjects    ClassSubject[]
  exams            Exam[]
  quizzes          Quiz[]
  subjectLoads     SubjectLoad[]
  timetableEntries TimetableEntry[]
  /// Overrides the class shift, so 8A can be a morning group and 8B afternoon.
  shift            SchoolShift?        @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  shiftId          String?

  @@unique([schoolId, classId, name])
  @@index([schoolId])
  @@index([classId])
  @@map("sections")
}

/// School-level subject catalog. Linked to Class+Section via TeacherAssignment.
model Subject {
  id        String       @id @default(cuid())
  schoolId  String
  name      String
  code      String?
  status    EntityStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  school                 School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments            TeacherAssignment[]
  classSubjects          ClassSubject[]
  examSubjects           ExamSubject[]
  examMarks              ExamMark[]
  quizzes                Quiz[]
  subjectLoads           SubjectLoad[]
  timetableEntries       TimetableEntry[]
  subjectTimePreferences SubjectTimePreference[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// Class ↔ Subject assignment (which subjects are taught in a class/section).
/// A null section means the subject applies to the whole class.
model ClassSubject {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, sectionId, subjectId])
  @@index([schoolId])
  @@index([classId])
  @@map("class_subjects")
}

/// System user. Unique per school (not globally) — hence composite constraints.
model User {
  id           String     @id @default(cuid())
  schoolId     String
  username     String
  /// Human-friendly account code (e.g. USR-000001), unique per school.
  code         String?
  /// Display name shown in the admin UI.
  fullName     String?
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  parent        Parent?
  teacher       Teacher?

  @@unique([schoolId, username])
  @@index([schoolId])
  @@map("users")
}

/// Hashed refresh tokens for JWT session rotation. System-level (no RLS):
/// looked up by the (globally unique, random) token hash during refresh.
model RefreshToken {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Append-only audit trail (Module 18). Denormalized (keeps username/role
/// snapshots) so entries survive user deletion. Tenant-scoped via RLS.
model AuditLog {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String?
  username  String?
  role      UserRole?
  module    String
  action    String
  ip        String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([schoolId, createdAt])
  @@map("audit_logs")
}

/// Per-school, per-entity sequence for generating human IDs (e.g. SHMM0001).
/// System table (no RLS); written on the privileged connection with explicit
/// schoolId. Values are never reused, so gaps on failure are acceptable.
model Counter {
  id       String @id @default(cuid())
  schoolId String
  name     String
  value    Int    @default(0)

  @@unique([schoolId, name])
  @@map("counters")
}

/// Parent/guardian. Auto-created from student registration; reused by phone.
/// Logs in via the linked User (username = parent code).
model Parent {
  id         String       @id @default(cuid())
  schoolId   String
  code       String
  name       String
  phone      String
  altPhone   String?
  email      String?
  address    String?
  occupation String?
  status     EntityStatus @default(ACTIVE)
  userId     String       @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([schoolId, code])
  @@unique([schoolId, phone])
  @@index([schoolId])
  @@map("parents")
}

/// Student — foundation of the ERP. Belongs to one Class + (optional) Section.
model Student {
  id                   String        @id @default(cuid())
  schoolId             String
  code                 String
  fullName             String
  gender               Gender
  dob                  DateTime?
  phone                String?
  notes                String?
  photoKey             String?
  portalPasswordHash   String?
  parentId             String
  classId              String
  sectionId            String?
  monthlyFee           Int           @default(0)
  annualFeeAmount      Int?
  feeStartMode         FeeStartMode?
  feeAgreementAmount   Int?
  feeBillingStartYear  Int?
  feeBillingStartMonth Int?
  status               StudentStatus @default(ACTIVE)
  registrationDate     DateTime      @default(now())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  parent       Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  class        Class               @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section?            @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  attendance   StudentAttendance[]
  feeCharges   FeeCharge[]
  payments     Payment[]
  examMarks    ExamMark[]
  blocked      BlockedStudent[]
  promotions   PromotionRecord[]
  quizAttempts QuizAttempt[]
  bookLoans    BookLoan[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([parentId])
  @@index([classId])
  @@map("students")
}

/// Teacher (Module 3). Logs in via linked User (username = teacher code).
model Teacher {
  id               String           @id @default(cuid())
  schoolId         String
  code             String
  fullName         String
  phone            String?
  email            String?
  address          String?
  qualification    String?
  gender           Gender
  salary           Int              @default(0)
  shift            Shift
  status           EmploymentStatus @default(ACTIVE)
  /// Explicit admin grant — teachers cannot browse students without this.
  canViewStudents  Boolean          @default(false)
  userId           String           @unique
  registrationDate DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments      TeacherAssignment[]
  attendance       TeacherAttendance[]
  quizzes          Quiz[]
  unavailability   TeacherUnavailability[]
  timetableEntries TimetableEntry[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("teachers")
}

/// Teacher assignment (Module 4): one independent row per
/// Teacher × AcademicYear × Class × Section × Subject.
///
/// Valid examples (all allowed for the same teacher):
/// - Grade 7 / Section A / Mathematics
/// - Grade 7 / Section A / Physics
/// - Grade 7 / Section B / Mathematics
/// - Grade 8 / Section A / Mathematics
///
/// sectionId = null means "all sections" of the class.
/// Exact duplicates only: same teacher + year + class + section + subject.
/// Uniqueness is enforced by index teacher_assignments_exact_dup_key
/// (COALESCE(sectionId,'') so NULL sections are included).
model TeacherAssignment {
  id             String   @id @default(cuid())
  schoolId       String
  teacherId      String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  /// Which shift THIS slot is taught in. Only meaningful — and only ever
  /// asked for — when the teacher's own profile is BOTH; a single-shift
  /// teacher's assignments inherit their one shift without being asked.
  /// Never BOTH itself: enforced by a CHECK constraint (see migration).
  shift          Shift?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
  @@index([schoolId, teacherId, academicYearId])
  @@index([schoolId, classId, sectionId, subjectId, academicYearId])
  @@map("teacher_assignments")
}

/// Daily student attendance (Module 5). One record per student per day.
model StudentAttendance {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  classId        String
  sectionId      String?
  academicYearId String
  date           DateTime         @db.Date
  status         AttendanceStatus
  markedByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, date])
  @@index([schoolId, date])
  @@index([classId, sectionId, date])
  @@map("student_attendance")
}

/// Daily teacher attendance (Module 6). Shift-scoped. One record per day.
model TeacherAttendance {
  id             String           @id @default(cuid())
  schoolId       String
  teacherId      String
  shift          Shift
  date           DateTime         @db.Date
  status         AttendanceStatus
  markedByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, date])
  @@index([schoolId, date])
  @@map("teacher_attendance")
}

/// A fee charge on a student's account (Module 7).
///
/// MONTHLY rows are the regular school fee — still exactly one per student per
/// year+month, enforced by a PARTIAL unique index (`kind = 'MONTHLY'`) created
/// in the migration rather than a plain @@unique here, so that EXTRA rows can
/// sit alongside them in the same month.
model FeeCharge {
  id             String        @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String?
  year           Int
  month          Int
  amount         Int
  paidAmount     Int           @default(0)
  status         FeeStatus     @default(UNPAID)
  kind           FeeChargeKind @default(MONTHLY)
  /// Shown on the invoice/history for EXTRA rows, e.g. "Exam Fee". Denormalised
  /// from ExtraFee.name so a receipt still reads correctly if the setup is renamed.
  label          String?
  extraFeeId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  extraFee     ExtraFee?     @relation(fields: [extraFeeId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([extraFeeId])
  @@index([schoolId, studentId, year, month])
  @@map("fee_charges")
}

/// An additional, one-off charge the school sets up separately from the regular
/// monthly fee — e.g. an exam fee billed into a particular month. Applying it
/// creates EXTRA FeeCharge rows on top of that month's normal fee.
model ExtraFee {
  id                  String  @id @default(cuid())
  schoolId            String
  academicYearId      String?
  name                String
  description         String?
  /// The month this is billed into, alongside that month's regular fee.
  year                Int
  month               Int
  /// Used when appliesToAllClasses is true. Ignored otherwise.
  defaultAmount       Int?
  /// true = every active class at `defaultAmount`; false = only the classes in
  /// classAmounts, each at its own price.
  appliesToAllClasses Boolean @default(true)

  status          EntityStatus @default(ACTIVE)
  /// Set the first time it is pushed onto students; used to show "applied" state.
  appliedAt       DateTime?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  academicYear AcademicYear?         @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  classAmounts ExtraFeeClassAmount[]
  charges      FeeCharge[]

  @@index([schoolId])
  @@index([academicYearId])
  @@map("extra_fees")
}

/// Per-class price for an ExtraFee when it isn't a single flat amount.
model ExtraFeeClassAmount {
  id         String @id @default(cuid())
  schoolId   String
  extraFeeId String
  classId    String
  amount     Int

  extraFee ExtraFee @relation(fields: [extraFeeId], references: [id], onDelete: Cascade)
  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([extraFeeId, classId])
  @@index([schoolId])
  @@index([classId])
  @@map("extra_fee_class_amounts")
}

/// One-time academic year fee activation per school year (Academic Year billing mode).
model AcademicYearFeeSetup {
  id                String   @id @default(cuid())
  schoolId          String
  academicYearId    String
  academicMonths    Int
  billingStartMonth Int
  billingEndMonth   Int
  monthlyFee        Int?
  totalAnnualFee    Int
  activatedAt       DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId])
  @@index([schoolId])
  @@map("academic_year_fee_setups")
}

/// A fee payment with a receipt (Module 7).
model Payment {
  id                String      @id @default(cuid())
  schoolId          String
  studentId         String
  receiptNumber     String
  type              PaymentType
  amount            Int
  method            String?
  collectedByUserId String?
  note              String?
  paidAt            DateTime    @default(now())
  createdAt         DateTime    @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, receiptNumber])
  @@index([schoolId])
  @@index([studentId])
  @@map("payments")
}

/// Salary record for an employee (Module 8).
model Salary {
  id           String       @id @default(cuid())
  schoolId     String
  teacherId    String?
  employeeName String
  position     String?
  amount       Int
  year         Int
  month        Int
  status       SalaryStatus @default(PENDING)
  paidAt       DateTime?
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([schoolId])
  @@map("salaries")
}

/// Expense category (Module 9).
model ExpenseCategory {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("expense_categories")
}

/// Operational expense (Module 9).
model Expense {
  id               String   @id @default(cuid())
  schoolId         String
  categoryId       String?
  title            String
  amount           Int
  method           String?
  note             String?
  recordedByUserId String?
  spentAt          DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@map("expenses")
}

// ── Examinations (Module 11) ────────────────────────────────────────────────

model ExamGroup {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams        Exam[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@map("exam_groups")
}

model Exam {
  id              String     @id @default(cuid())
  schoolId        String
  academicYearId  String
  examGroupId     String?
  name            String
  examType        ExamType   @default(TEACHER_ASSESSMENT)
  term            String
  maxMarks        Int        @default(100)
  weightPercent   Int        @default(100)
  startDate       DateTime   @db.Date
  endDate         DateTime   @db.Date
  status          ExamStatus @default(DRAFT)
  classId         String
  sectionId       String?
  createdByUserId String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examGroup    ExamGroup?       @relation(fields: [examGroupId], references: [id], onDelete: SetNull)
  class        Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjects     ExamSubject[]
  marks        ExamMark[]
  blocked      BlockedStudent[]

  @@index([schoolId])
  @@index([classId, sectionId])
  @@map("exams")
}

model ExamSubject {
  id               String           @id @default(cuid())
  schoolId         String
  examId           String
  subjectId        String
  teacherId        String?
  submissionStatus SubmissionStatus @default(PENDING)
  submittedAt      DateTime?
  createdAt        DateTime         @default(now())

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, examId, subjectId])
  @@index([examId])
  @@map("exam_subjects")
}

model ExamMark {
  id              String    @id @default(cuid())
  schoolId        String
  examId          String
  studentId       String
  subjectId       String
  /// Stored as a float so a subject can be marked to one or two decimals
  /// (e.g. 15.8 / 20). Totals and averages are computed from these.
  marks           Float?
  enteredByUserId String?
  enteredAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@map("exam_marks")
}

model BlockedStudent {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  examId          String?
  academicYearId  String
  reason          String
  blockedByUserId String?
  blockedAt       DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam?   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@map("blocked_students")
}

// ── Promotions (Module 13) ──────────────────────────────────────────────────

model PromotionRecord {
  id               String        @id @default(cuid())
  schoolId         String
  studentId        String
  academicYearId   String
  type             PromotionType
  fromClassId      String
  fromSectionId    String?
  toClassId        String?
  toSectionId      String?
  graduated        Boolean       @default(false)
  promotedAt       DateTime      @default(now())
  promotedByUserId String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@map("promotion_records")
}

// ── Quiz (Module 12) ──────────────────────────────────────────────────────

model Quiz {
  id                     String     @id @default(cuid())
  schoolId               String
  academicYearId         String
  classId                String
  sectionId              String?
  subjectId              String?
  teacherId              String
  title                  String
  code                   String
  description            String?
  status                 QuizStatus @default(DRAFT)
  timeLimitMin           Int?
  maxAttempts            Int        @default(1)
  passingMarks           Int?
  startAt                DateTime?
  endAt                  DateTime?
  shuffleQuestions       Boolean    @default(false)
  shuffleAnswers         Boolean    @default(false)
  showResultsImmediately Boolean    @default(true)
  allowReviewAnswers     Boolean    @default(true)
  allowPdfDownload       Boolean    @default(true)
  instructions           String?
  examinationRules       String?
  preventMinimize        Boolean    @default(false)
  disableCopyPaste       Boolean    @default(false)
  resetOnMinimize        Boolean    @default(false)
  publishedAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  academicYear AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacher      Teacher             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  activities   QuizActivityEvent[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([teacherId])
  @@map("quizzes")
}

model QuizQuestion {
  id                  String   @id @default(cuid())
  schoolId            String
  quizId              String
  question            String
  // MCQ | DIRECT | MATCH | FILL_BLANK (legacy: ESSAY | SHORT_ANSWER)
  questionType        String   @default("MCQ")
  options             Json
  correctAnswer       String   @default("")
  // EXACT (string match) | AI_CONCEPT (OpenAI-scored) — only honoured for DIRECT.
  gradingMode         String   @default("EXACT")
  // MATCH: [{ left, right }] correct pairs. FILL_BLANK: ["ans1","ans2",...] per blank.
  pairs               Json?
  blanks              Json?
  marks               Int      @default(1)
  requiresManualGrade Boolean  @default(false)
  orderIndex          Int      @default(0)
  createdAt           DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id             String            @id @default(cuid())
  schoolId       String
  quizId         String
  studentId      String
  status         QuizAttemptStatus @default(IN_PROGRESS)
  score          Int?
  percentage     Float?
  result         String?
  grade          String?
  teacherComment String?
  startedAt      DateTime          @default(now())
  submittedAt    DateTime?

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id                String  @id @default(cuid())
  schoolId          String
  attemptId         String
  questionId        String
  answer            String?
  isCorrect         Boolean @default(false)
  marks             Int     @default(0)
  // 0-100 similarity for AI-graded DIRECT answers; null for exact-graded types.
  awardedPercentage Float?
  aiFeedback        String?
  markedForReview   Boolean @default(false)

  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([schoolId, attemptId, questionId])
  @@map("quiz_answers")
}

/// Per-student quiz participation timeline (link opened → login → start → submit).
model QuizActivityEvent {
  id        String   @id @default(cuid())
  schoolId  String
  quizId    String
  studentId String
  /// LINK_OPENED | LOGGED_IN | QUIZ_STARTED | QUIZ_SUBMITTED | SCORE_GENERATED | TIME_EXPIRED
  event     String
  meta      Json?
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, studentId])
  @@index([schoolId])
  @@map("quiz_activity_events")
}

// ── Announcements & Notifications (Module 17) ───────────────────────────────

model Announcement {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  body            String
  audience        String   @default("ALL")
  publishedAt     DateTime @default(now())
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([schoolId])
  @@map("announcements")
}

model Notification {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String?
  parentId  String?
  title     String
  body      String
  type      String    @default("INFO")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([parentId])
  @@map("notifications")
}

// ── Backup & Import jobs (Modules 19, 22) ─────────────────────────────────

model BackupJob {
  id          String    @id @default(cuid())
  schoolId    String
  status      JobStatus @default(PENDING)
  storageKey  String?
  sizeBytes   Int?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([schoolId])
  @@map("backup_jobs")
}

model ImportJob {
  id          String    @id @default(cuid())
  schoolId    String
  type        String
  status      JobStatus @default(PENDING)
  fileKey     String?
  summary     Json?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([schoolId])
  @@map("import_jobs")
}

/// Library (Module 16): book catalogue. Managed by ADMINISTRATOR + LIBRARIAN.
model Book {
  id              String       @id @default(cuid())
  schoolId        String
  title           String
  author          String?
  isbn            String?
  category        String?
  totalCopies     Int          @default(1)
  availableCopies Int          @default(1)
  status          EntityStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  loans BookLoan[]

  @@index([schoolId])
  @@map("books")
}

/// Library (Module 16): a PDF book/notes file students read in their portal.
/// Separate from `Book` because a digital file has no copies to lend — it has
/// a stored file, an audience, and a read/download permission instead.
model LibraryDocument {
  id          String  @id @default(cuid())
  schoolId    String
  title       String
  description String?
  author      String?

  /// null = every student in the school may read it. Set = only this class,
  /// so a book meant for one grade never shows up for another.
  classId String?
  class   Class?  @relation(fields: [classId], references: [id], onDelete: Restrict)

  /// Storage key, namespaced by tenant: `${schoolId}/library/${id}.pdf`.
  fileKey       String
  fileSizeBytes Int
  /// When false the portal only streams it for on-screen reading.
  allowDownload Boolean @default(false)

  status           EntityStatus @default(ACTIVE)
  uploadedByUserId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@map("library_documents")
}

/// A book issued to a student; returned when the copy comes back.
model BookLoan {
  id             String     @id @default(cuid())
  schoolId       String
  bookId         String
  studentId      String
  issuedAt       DateTime   @default(now())
  dueDate        DateTime   @db.Date
  returnedAt     DateTime?
  status         LoanStatus @default(ISSUED)
  issuedByUserId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  book    Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([bookId])
  @@index([studentId])
  @@map("book_loans")
}

enum FeeStatus {
  UNPAID
  PARTIAL
  PAID
  INACTIVE
}

/// MONTHLY = the regular school fee. EXTRA = an additional charge (exam fee etc.)
/// billed into the same month on top of it.
enum FeeChargeKind {
  MONTHLY
  EXTRA
}

enum BillingMode {
  MONTHLY
  ACADEMIC_YEAR
}

enum FeeStartMode {
  FULL_CURRENT
  AGREEMENT
  NEXT_MONTH
}

enum PaymentType {
  THIS_MONTH
  PARTIAL
  ADVANCE
}

enum SalaryStatus {
  PENDING
  PAID
  PARTIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum Shift {
  MORNING
  AFTERNOON
  /// A teacher who works both shifts. Never valid on a single TeacherAssignment
  /// row — an assignment is one class in one shift — only on the teacher's own
  /// profile, where it means "ask which shift" whenever they're assigned.
  BOTH
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
}

/// Generic active/inactive status for classes, sections, subjects, parents.
enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum LoanStatus {
  ISSUED
  RETURNED
  OVERDUE
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

/// Platform-level Super Admin — operates ABOVE all schools (multi-tenant SaaS
/// operator). Not tied to any school; manages/creates/suspends tenants.
enum PlatformAdminRole {
  SUPER_ADMIN
  OPERATOR
}

model PlatformAdmin {
  id           String            @id @default(cuid())
  username     String            @unique
  name         String
  passwordHash String
  /// SUPER_ADMIN: full platform control including subscription mutations.
  /// OPERATOR: read-only for billing/subscriptions (and other gated modules).
  role         PlatformAdminRole @default(SUPER_ADMIN)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  refreshTokens PlatformRefreshToken[]

  @@map("platform_admins")
}

/// Rotating refresh tokens for platform Super Admin sessions.
model PlatformRefreshToken {
  id        String    @id @default(cuid())
  adminId   String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  admin PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("platform_refresh_tokens")
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  ADMINISTRATOR
  TEACHER
  PARENT
  STUDENT
  ATTENDANCE_OFFICER
  FINANCE_OFFICER
  EXAM_MANAGER
  RECEPTION
  SUPER_ADMINISTRATOR
  ACADEMIC_MANAGER
  RECEPTION_OFFICER
  LIBRARIAN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum ExamType {
  TEACHER_ASSESSMENT
  SCHOOL_IMPORT
}

enum ExamStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  LOCKED
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  LOCKED
}

enum PromotionType {
  INDIVIDUAL
  CLASS
  SCHOOL_WIDE
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  PENDING_REVIEW
  GRADED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ── SMS Module (Hormuud) ────────────────────────────────────────────────────

/// Global Hormuud API credentials + feature switch (platform Super Admin only).
/// Single-row table; credentials are never exposed to school tenants.
/// Platform-wide AI (OpenAI) config for quiz auto-grading. Managed by the
/// Super Admin only; the API key is entered through the platform panel.
model AiGlobalConfig {
  id                String    @id @default(cuid())
  enabled           Boolean   @default(false)
  provider          String    @default("openai")
  apiKey            String    @default("")
  model             String    @default("gpt-4o-mini")
  connectionStatus  String    @default("DISCONNECTED")
  connectionMessage String?
  lastTestedAt      DateTime?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  @@map("ai_global_config")
}

model SmsGlobalConfig {
  id                 String    @id @default(cuid())
  enabled            Boolean   @default(false)
  baseUrl            String    @default("https://smsapi.hormuud.com")
  username           String    @default("")
  /// API password (Hormuud portal "API PASSWORD")
  password           String    @default("")
  /// Optional default sender if a school has none configured
  defaultSenderId    String?
  /// CONNECTED | DISCONNECTED | ERROR
  connectionStatus   String    @default("DISCONNECTED")
  connectionMessage  String?
  lastTestedAt       DateTime?
  lastSuccessAt      DateTime?
  providerBalance    String?
  /// Must be true (successful Test Connection) before packages can be managed.
  connectionVerified Boolean   @default(false)
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@map("sms_global_config")
}

/// Platform-only audit trail for Hormuud connection tests and config changes.
model SmsConnectionLog {
  id        String   @id @default(cuid())
  action    String // TEST | SAVE | ENABLE | DISABLE | ERROR
  success   Boolean  @default(false)
  status    String // CONNECTED | DISCONNECTED | ERROR
  message   String
  details   Json?
  adminId   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("sms_connection_logs")
}

/// A school's OWN Hormuud credentials, so its SMS goes out through its own
/// provider account instead of the platform's shared one (and off the
/// platform credit system). Gated by an SmsGatewayLicense sold by Super Admin.
/// Not tenant-scoped/RLS: like `schools`, it is keyed by schoolId and only
/// ever read through the authenticated school's own id.
model SchoolSmsGateway {
  id       String @id @default(cuid())
  schoolId String @unique

  /// School's switch. Only takes effect while a license is active.
  enabled  Boolean @default(false)
  baseUrl  String  @default("https://smsapi.hormuud.com")
  username String  @default("")
  /// API password (Hormuud portal "API PASSWORD"). Never returned by the API.
  password String  @default("")
  senderId String?

  /// CONNECTED | DISCONNECTED | ERROR
  connectionStatus   String    @default("DISCONNECTED")
  connectionMessage  String?
  lastTestedAt       DateTime?
  lastSuccessAt      DateTime?
  providerBalance    String?
  /// Must be true (successful Test Connection) before sending through it.
  connectionVerified Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_sms_gateways")
}

/// Super Admin grant letting a school use its own SMS gateway for a period.
/// Kept as a history table (like SmsPurchase) rather than a column so renewals
/// and pricing stay auditable.
model SmsGatewayLicense {
  id               String   @id @default(cuid())
  schoolId         String
  startDate        DateTime @default(now())
  endDate          DateTime
  /// ACTIVE | EXPIRED | CANCELLED
  status           String   @default("ACTIVE")
  /// Billing period sold, e.g. 6 or 12 months.
  durationMonths   Int
  price            Decimal? @db.Decimal(12, 2)
  currency         String   @default("USD")
  note             String?
  createdByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([status, endDate])
  @@map("sms_gateway_licenses")
}

/// Sellable SMS credit packages managed by Super Admin.
model SmsPackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// Number of SMS credits included
  credits     Int
  /// Price charged to the school (school currency units)
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases     SmsPurchase[]
  paymentOrders SmsPaymentOrder[]

  @@map("sms_packages")
}

/// A school's purchased package / credit wallet.
model SmsPurchase {
  id               String            @id @default(cuid())
  schoolId         String
  packageId        String
  creditsTotal     Int
  creditsRemaining Int
  amountPaid       Decimal           @db.Decimal(12, 2)
  currency         String            @default("USD")
  status           SmsPurchaseStatus @default(ACTIVE)
  purchasedAt      DateTime          @default(now())
  expiresAt        DateTime?
  note             String?
  createdByAdminId String?
  /// Linked Waafi payment order when purchased via gateway (null = admin assign).
  paymentOrderId   String?           @unique

  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  package      SmsPackage       @relation(fields: [packageId], references: [id])
  paymentOrder SmsPaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  messages     SmsMessage[]
  transactions SmsTransaction[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("sms_purchases")
}

/// Platform-only Hormuud WaafiPay gateway credentials (Super Admin).
/// Single-row table; never exposed to school tenants.
model WaafiPaymentConfig {
  id                 String    @id @default(cuid())
  enabled            Boolean   @default(false)
  /// Sandbox: https://sandbox.waafipay.net/asm  Live: https://api.waafipay.net/asm
  baseUrl            String    @default("https://sandbox.waafipay.net/asm")
  merchantUid        String    @default("")
  /// Direct API purchase credentials
  apiUserId          String    @default("")
  apiKey             String    @default("")
  /// Hosted Payment Page credentials
  storeId            String    @default("")
  hppKey             String    @default("")
  /// API_PURCHASE | HPP_PURCHASE
  defaultMethod      String    @default("API_PURCHASE")
  currency           String    @default("USD")
  /// Public HTTPS base for Waafi callbacks (e.g. https://api.example.com)
  callbackBaseUrl    String?
  connectionStatus   String    @default("DISCONNECTED") // CONNECTED | DISCONNECTED | ERROR
  connectionMessage  String?
  lastTestedAt       DateTime?
  lastSuccessAt      DateTime?
  connectionVerified Boolean   @default(false)
  /// When true, purchases succeed without calling Waafi (dev / demo only).
  simulationMode     Boolean   @default(false)
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@map("waafi_payment_config")
}

/// SMS package payment order via WaafiPay (tenant-scoped).
model SmsPaymentOrder {
  id                 String           @id @default(cuid())
  schoolId           String
  packageId          String
  /// Merchant reference sent to Waafi (unique). Used for reconciliation.
  referenceId        String           @unique
  invoiceId          String
  amount             Decimal          @db.Decimal(12, 2)
  currency           String           @default("USD")
  credits            Int
  status             SmsPaymentStatus @default(PENDING)
  paymentMethod      String           @default("MWALLET_ACCOUNT")
  /// API_PURCHASE | HPP_PURCHASE
  channel            String           @default("API_PURCHASE")
  payerAccount       String?
  receiptNumber      String?          @unique
  waafiRequestId     String?
  waafiOrderId       String?
  waafiTransactionId String?          @unique
  waafiIssuerTxnId   String?
  hppUrl             String?
  requestPayload     Json?
  responsePayload    Json?
  callbackPayload    Json?
  verifyPayload      Json?
  failureReason      String?
  initiatedByUserId  String?
  paidAt             DateTime?
  expiresAt          DateTime?
  activatedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  school    School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  package   SmsPackage           @relation(fields: [packageId], references: [id])
  purchase  SmsPurchase?
  auditLogs SmsPaymentAuditLog[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([status, createdAt])
  @@map("sms_payment_orders")
}

/// Append-only audit trail for SMS payment lifecycle events.
model SmsPaymentAuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  orderId   String
  action    String // CREATED | WAAFI_REQUEST | WAAFI_RESPONSE | CALLBACK | VERIFY | ACTIVATED | FAILED | EXPIRED | REFUND
  success   Boolean  @default(false)
  message   String
  details   Json?
  actorId   String?
  createdAt DateTime @default(now())

  order SmsPaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([schoolId, createdAt])
  @@map("sms_payment_audit_logs")
}

/// Per-message log (every outbound SMS).
model SmsMessage {
  id                String            @id @default(cuid())
  schoolId          String
  purchaseId        String?
  campaignId        String?
  category          SmsCategory       @default(CUSTOM)
  recipientPhone    String
  recipientName     String?
  recipientType     String? // PARENT | STUDENT | TEACHER | STAFF | OTHER
  recipientRefId    String? // parentId / studentId / teacherId
  senderId          String
  body              String
  creditsUsed       Int               @default(1)
  status            SmsDeliveryStatus @default(PENDING)
  providerMessageId String?
  providerRefId     String?
  providerCode      String?
  providerMessage   String?
  error             String?
  retryCount        Int               @default(0)
  scheduledAt       DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdByUserId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  purchase SmsPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  campaign SmsCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, createdAt])
  @@index([providerMessageId])
  @@map("sms_messages")
}

/// Reusable message templates with {{variable}} placeholders.
model SmsTemplate {
  id        String      @id @default(cuid())
  schoolId  String
  name      String
  category  SmsCategory @default(CUSTOM)
  body      String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("sms_templates")
}

/// Batch / scheduled / automated campaigns (fee reminders, announcements, etc.).
model SmsCampaign {
  id                   String            @id @default(cuid())
  schoolId             String
  name                 String
  category             SmsCategory       @default(CUSTOM)
  body                 String
  status               SmsCampaignStatus @default(DRAFT)
  audience             String            @default("CUSTOM") // ALL_PARENTS | CLASS | SECTION | CUSTOM | OUTSTANDING
  classId              String?
  sectionId            String?
  scheduledAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  totalRecipients      Int               @default(0)
  sentCount            Int               @default(0)
  failedCount          Int               @default(0)
  creditsUsed          Int               @default(0)
  /// Automation: fee reminder interval in days (null = one-shot)
  reminderIntervalDays Int?
  lastRunAt            DateTime?
  createdByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  messages SmsMessage[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@map("sms_campaigns")
}

/// Credit ledger (purchase, deduction, adjustment, refund).
model SmsTransaction {
  id              String             @id @default(cuid())
  schoolId        String
  purchaseId      String?
  type            SmsTransactionType
  credits         Int
  /// Positive = credit added; negative = deducted
  balanceAfter    Int
  description     String?
  messageId       String?
  createdByUserId String?
  createdAt       DateTime           @default(now())

  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  purchase SmsPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, createdAt])
  @@map("sms_transactions")
}

enum SmsPurchaseStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELLED
}

enum SmsDeliveryStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum SmsCategory {
  CUSTOM
  FEE_REMINDER
  ANNOUNCEMENT
  EMERGENCY
  ATTENDANCE
  EXAM_ANNOUNCEMENT
  EXAM_RESULT
  ADMISSION
  REGISTRATION
  PAYMENT_CONFIRMATION
}

enum SmsCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  CANCELLED
  FAILED
}

enum SmsTransactionType {
  PURCHASE
  DEDUCTION
  ADJUSTMENT
  REFUND
}

enum SmsPaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

/// Platform-level subscription plan catalog (Super Admin managed, not
/// tenant-scoped — same pattern as SmsPackage). Null limits = unlimited.
model SubscriptionPlan {
  id                    String   @id @default(cuid())
  name                  String   @unique
  maxStudents           Int?
  maxTeachers           Int?
  durationDays          Int
  aiGradingMonthlyQuota Int?
  /// Total size of all uploaded library PDFs a school may store. Null = unlimited.
  libraryStorageMb      Int?
  priceUsd              Decimal? @db.Decimal(12, 2)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions SchoolSubscription[]
  paymentOrders SubscriptionPaymentOrder[]

  @@map("subscription_plans")
}

enum SchoolSubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// A school's currently assigned plan. One active row per school — Super
/// Admin assigns/renews manually (no self-service billing yet). Enforcement
/// (student cap, AI grading quota) is per-feature, not a whole-tenant lockout.
model SchoolSubscription {
  id                   String                   @id @default(cuid())
  schoolId             String                   @unique
  planId               String
  status               SchoolSubscriptionStatus @default(ACTIVE)
  startDate            DateTime                 @default(now())
  endDate              DateTime
  aiGradingUsed        Int                      @default(0)
  aiGradingResetAt     DateTime                 @default(now())
  assignedByAdminId    String?
  assignedByUsername   String?
  /// Last expiry warning sent: 7 | 3 | 1 (or null if none this cycle).
  lastExpiryNoticeDays Int?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@map("school_subscriptions")
}

/// Immutable history row for every assign / cancel / expire / renew.
model SubscriptionHistory {
  id                 String                   @id @default(cuid())
  schoolId           String
  planId             String
  planName           String
  status             SchoolSubscriptionStatus
  startDate          DateTime
  endDate            DateTime
  assignedByAdminId  String?
  assignedByUsername String?
  action             String
  createdAt          DateTime                 @default(now())

  @@index([schoolId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@map("subscription_history")
}

/// Platform Super Admin audit trail (no schoolId required).
model PlatformAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  username  String?
  schoolId  String?
  action    String
  module    String   @default("subscriptions")
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([adminId, createdAt])
  @@index([schoolId, createdAt])
  @@map("platform_audit_logs")
}

enum SubscriptionPaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

/// A school's self-service WaafiPay purchase of a subscription plan.
/// Mirrors SmsPaymentOrder — same merchant / gateway config, same
/// activate-on-success flow, just applied to plan assignment instead of
/// SMS credits.
model SubscriptionPaymentOrder {
  id                 String                    @id @default(cuid())
  schoolId           String
  planId             String
  /// Merchant reference sent to Waafi (unique). Used for reconciliation.
  referenceId        String                    @unique
  invoiceId          String
  amount             Decimal                   @db.Decimal(12, 2)
  currency           String                    @default("USD")
  status             SubscriptionPaymentStatus @default(PENDING)
  paymentMethod      String                    @default("MWALLET_ACCOUNT")
  /// API_PURCHASE | HPP_PURCHASE
  channel            String                    @default("API_PURCHASE")
  payerAccount       String?
  receiptNumber      String?                   @unique
  waafiRequestId     String?
  waafiOrderId       String?
  waafiTransactionId String?                   @unique
  waafiIssuerTxnId   String?
  hppUrl             String?
  requestPayload     Json?
  responsePayload    Json?
  callbackPayload    Json?
  verifyPayload      Json?
  failureReason      String?
  initiatedByUserId  String?
  paidAt             DateTime?
  expiresAt          DateTime?
  activatedAt        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  plan      SubscriptionPlan              @relation(fields: [planId], references: [id])
  auditLogs SubscriptionPaymentAuditLog[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([status, createdAt])
  @@map("subscription_payment_orders")
}

model SubscriptionPaymentAuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  orderId   String
  action    String // CREATED | WAAFI_REQUEST | WAAFI_RESPONSE | CALLBACK | VERIFY | ACTIVATED | FAILED | EXPIRED
  success   Boolean  @default(false)
  message   String
  details   Json?
  actorId   String?
  createdAt DateTime @default(now())

  order SubscriptionPaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([schoolId, createdAt])
  @@map("subscription_payment_audit_logs")
}

// ───────────────────────────────────────────────────────────────────────────
// Timetable (Module 12). Phase 1: data model + database-level anti-clash rules.
//
// Times are stored as MINUTES FROM MIDNIGHT (07:50 = 470) rather than DateTime.
// A timetable slot is a wall-clock position in a weekday, not an instant, so
// minutes keep the maths exact, timezone-free, and directly comparable ACROSS
// shifts — which is what makes it possible to prove one teacher is never in two
// rooms at once when a school runs a morning and an afternoon shift.
//
// Weekdays use the JavaScript getDay() convention: 0 = Sunday … 6 = Saturday.
// ───────────────────────────────────────────────────────────────────────────

/// A block of the school day (Morning / Afternoon). A school runs one or two.
/// Each shift owns its own daily grid, so the afternoon can be shorter than the
/// morning and have its break somewhere else.
model SchoolShift {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  orderIndex     Int          @default(0)
  /// Working days for this shift, e.g. [6,0,1,2,3] = Saturday–Wednesday.
  days           Int[]
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  academicYear AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  periods      ShiftPeriod[]
  classes      Class[]
  sections     Section[]
  timetables   Timetable[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@map("school_shifts")
}

/// One row of a shift's daily grid — either a lesson slot or a break.
/// Lengths are deliberately per-period: real schools run 43-minute periods
/// before the break and 30-minute ones after it.
model ShiftPeriod {
  id          String   @id @default(cuid())
  schoolId    String
  shiftId     String
  name        String
  orderIndex  Int
  startMinute Int
  endMinute   Int
  /// Breaks occupy the grid but are never filled with a lesson.
  isBreak     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shift   SchoolShift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  entries TimetableEntry[]

  @@unique([schoolId, shiftId, orderIndex])
  @@index([schoolId])
  @@index([shiftId])
  @@map("shift_periods")
}

/// How many periods a subject must get per week in one classroom — the
/// generator's source data (the "Lesson Allocation" grid).
///
/// Deliberately does NOT store a teacher: who teaches a subject in a class is
/// already TeacherAssignment's job, and duplicating it here would let the two
/// disagree. This table answers "how much", that one answers "by whom".
model SubjectLoad {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  periodsPerWeek Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, academicYearId, classId])
  @@map("subject_loads")
}

/// A window in which a teacher must not be scheduled ("never period 1 or 2",
/// "off Tuesday afternoon").
///
/// Stored as a wall-clock range on a weekday rather than a pointer to a period,
/// so a single rule automatically covers BOTH shifts a teacher works in.
model TeacherUnavailability {
  id          String   @id @default(cuid())
  schoolId    String
  teacherId   String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, teacherId])
  @@map("teacher_unavailability")
}

enum TimetableStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// One generated timetable for one shift. Kept as a version so a school can
/// regenerate, compare, and publish only when satisfied.
model Timetable {
  id             String          @id @default(cuid())
  schoolId       String
  academicYearId String
  shiftId        String
  name           String
  status         TimetableStatus @default(DRAFT)
  generatedAt    DateTime?
  /// Solver report: unmet soft rules and why, mirroring the validation summary
  /// a school expects to see printed on the timetable itself.
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  shift        SchoolShift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  entries      TimetableEntry[]

  @@index([schoolId])
  @@index([schoolId, academicYearId, shiftId])
  @@map("timetables")
}

/// A single lesson: this classroom, this weekday, this period.
model TimetableEntry {
  id            String  @id @default(cuid())
  schoolId      String
  timetableId   String
  classId       String
  sectionId     String?
  subjectId     String
  teacherId     String?
  shiftPeriodId String
  dayOfWeek     Int
  /// Copied from the period on write. Denormalised on purpose: the exclusion
  /// constraints below need the range on this row, and it is what lets the
  /// database — not just the solver — guarantee no double-booking.
  startMinute   Int
  endMinute     Int
  /// True only while the parent timetable is PUBLISHED. The exclusion
  /// constraints apply to active rows only, so several drafts can coexist
  /// without fighting each other or the live schedule.
  isActive      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timetable   Timetable   @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  class       Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  section     Section?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     Teacher?    @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  shiftPeriod ShiftPeriod @relation(fields: [shiftPeriodId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([timetableId])
  @@index([schoolId, teacherId, dayOfWeek])
  @@index([timetableId, classId, sectionId, dayOfWeek])
  @@map("timetable_entries")
}

/// A soft wish about WHEN a subject should fall — "Maths in the morning".
///
/// Deliberately separate from TeacherUnavailability, which is a hard rule. A
/// preference only reorders the solver's choices; it can never make a timetable
/// unsolvable, because a school should not lose its whole week to a nice-to-have.
model SubjectTimePreference {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  subjectId      String
  /// Null means the preference applies to every class taking this subject.
  classId        String?
  startMinute    Int
  endMinute      Int
  /// The sentence the admin approved, kept so the rule stays explainable.
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class        Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, academicYearId])
  @@map("subject_time_preferences")
}
