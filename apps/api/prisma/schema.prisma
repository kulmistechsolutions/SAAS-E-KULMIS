// eKulmis — Prisma schema.
// Multi-tenant SaaS: EVERY domain model carries `schoolId` (tenant key).
// PostgreSQL Row-Level Security (added in Phase 0.5 migration SQL) enforces
// isolation; all uniqueness is scoped per school.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// The tenant. One row per school. Root of all tenant-scoped data.
model School {
  id        String   @id @default(cuid())
  /// Subdomain used for tenant resolution, e.g. "iskuul1" -> iskuul1.app.com
  subdomain String   @unique
  name      String
  status    SchoolStatus @default(ACTIVE)

  // ── Settings & branding (Module 16 / §7) ──
  motto         String?
  address       String?
  phone         String?
  email         String?
  website       String?
  principalName String?
  logoKey       String? // MinIO object key (uploaded separately)
  stampKey      String?
  currency      String  @default("USD")
  timezone      String  @default("UTC")
  language      String  @default("en")
  receiptFooter String?
  reportFooter  String?
  resultFooter  String?

  // ── ID prefixes (auto-generated IDs derive from these) ──
  studentPrefix     String @default("STD")
  teacherPrefix     String @default("TCH")
  parentPrefix      String @default("PAR")
  receiptPrefix     String @default("RCP")
  invoicePrefix     String @default("INV")
  certificatePrefix String @default("CRT")

  /// Hormuud sender ID shown to recipients (defaults to school name when empty).
  smsSenderName String?
  smsEnabled    Boolean @default(true)

  // ── Fee billing (Module 7 dual mode) ──
  billingMode          BillingMode @default(MONTHLY)
  feeAcademicMonths    Int         @default(10)
  feeBillingStartMonth Int         @default(9)
  feeBillingEndMonth   Int         @default(6)
  feeAllowPartial      Boolean     @default(true)
  feeAllowAdvance      Boolean     @default(true)
  feeCarryForward      Boolean     @default(true)
  feeMonthSetupDay     Int         @default(25)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  subjects      Subject[]
  smsPurchases  SmsPurchase[]
  smsMessages   SmsMessage[]
  smsTemplates  SmsTemplate[]
  smsCampaigns  SmsCampaign[]
  smsTransactions SmsTransaction[]
  smsPaymentOrders SmsPaymentOrder[]

  @@map("schools")
}

/// Academic year (Module 13). At most one active per school (partial unique).
model AcademicYear {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes       Class[]
  assignments   TeacherAssignment[]
  classSubjects ClassSubject[]
  examGroups    ExamGroup[]
  exams         Exam[]
  quizzes       Quiz[]
  feeSetups     AcademicYearFeeSetup[]
  feeCharges    FeeCharge[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_years")
}

/// A grade within an academic year. Has many independent Sections.
model Class {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  orderIndex     Int          @default(0)
  hasSections    Boolean      @default(false)
  notes          String?
  status         EntityStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  academicYear  AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sections      Section[]
  students      Student[]
  assignments   TeacherAssignment[]
  classSubjects ClassSubject[]
  exams         Exam[]
  quizzes       Quiz[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@map("classes")
}

/// An independent classroom within a Class (§10). Never shares students/marks.
model Section {
  id        String       @id @default(cuid())
  schoolId  String
  classId   String
  name      String
  status    EntityStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  class         Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  students      Student[]
  assignments   TeacherAssignment[]
  classSubjects ClassSubject[]
  exams         Exam[]
  quizzes       Quiz[]

  @@unique([schoolId, classId, name])
  @@index([schoolId])
  @@index([classId])
  @@map("sections")
}

/// School-level subject catalog. Linked to Class+Section via TeacherAssignment.
model Subject {
  id        String       @id @default(cuid())
  schoolId  String
  name      String
  code      String?
  status    EntityStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments   TeacherAssignment[]
  classSubjects ClassSubject[]
  examSubjects  ExamSubject[]
  examMarks     ExamMark[]
  quizzes       Quiz[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// Class ↔ Subject assignment (which subjects are taught in a class/section).
/// A null section means the subject applies to the whole class.
model ClassSubject {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, sectionId, subjectId])
  @@index([schoolId])
  @@index([classId])
  @@map("class_subjects")
}

/// System user. Unique per school (not globally) — hence composite constraints.
model User {
  id           String     @id @default(cuid())
  schoolId     String
  username     String
  /// Human-friendly account code (e.g. USR-000001), unique per school.
  code         String?
  /// Display name shown in the admin UI.
  fullName     String?
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  parent        Parent?
  teacher       Teacher?

  @@unique([schoolId, username])
  @@index([schoolId])
  @@map("users")
}

/// Hashed refresh tokens for JWT session rotation. System-level (no RLS):
/// looked up by the (globally unique, random) token hash during refresh.
model RefreshToken {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Append-only audit trail (Module 18). Denormalized (keeps username/role
/// snapshots) so entries survive user deletion. Tenant-scoped via RLS.
model AuditLog {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String?
  username  String?
  role      UserRole?
  module    String
  action    String
  ip        String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([schoolId, createdAt])
  @@map("audit_logs")
}

/// Per-school, per-entity sequence for generating human IDs (e.g. SHMM0001).
/// System table (no RLS); written on the privileged connection with explicit
/// schoolId. Values are never reused, so gaps on failure are acceptable.
model Counter {
  id       String @id @default(cuid())
  schoolId String
  name     String
  value    Int    @default(0)

  @@unique([schoolId, name])
  @@map("counters")
}

/// Parent/guardian. Auto-created from student registration; reused by phone.
/// Logs in via the linked User (username = parent code).
model Parent {
  id         String       @id @default(cuid())
  schoolId   String
  code       String
  name       String
  phone      String
  altPhone   String?
  email      String?
  address    String?
  occupation String?
  status     EntityStatus @default(ACTIVE)
  userId     String       @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([schoolId, code])
  @@unique([schoolId, phone])
  @@index([schoolId])
  @@map("parents")
}

/// Student — foundation of the ERP. Belongs to one Class + (optional) Section.
model Student {
  id               String        @id @default(cuid())
  schoolId         String
  code             String
  fullName         String
  gender           Gender
  dob              DateTime?
  phone            String?
  notes            String?
  photoKey         String?
  portalPasswordHash String?
  parentId         String
  classId          String
  sectionId        String?
  monthlyFee       Int           @default(0)
  annualFeeAmount  Int?
  feeStartMode     FeeStartMode?
  feeAgreementAmount Int?
  feeBillingStartYear Int?
  feeBillingStartMonth Int?
  status           StudentStatus @default(ACTIVE)
  registrationDate DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  parent     Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  class      Class               @relation(fields: [classId], references: [id], onDelete: Restrict)
  section    Section?            @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  attendance StudentAttendance[]
  feeCharges FeeCharge[]
  payments   Payment[]
  examMarks  ExamMark[]
  blocked    BlockedStudent[]
  promotions PromotionRecord[]
  quizAttempts QuizAttempt[]
  bookLoans    BookLoan[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([parentId])
  @@index([classId])
  @@map("students")
}

/// Teacher (Module 3). Logs in via linked User (username = teacher code).
model Teacher {
  id               String           @id @default(cuid())
  schoolId         String
  code             String
  fullName         String
  phone            String?
  email            String?
  address          String?
  qualification    String?
  gender           Gender
  salary           Int              @default(0)
  shift            Shift
  status           EmploymentStatus @default(ACTIVE)
  /// Explicit admin grant — teachers cannot browse students without this.
  canViewStudents  Boolean          @default(false)
  userId           String           @unique
  registrationDate DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments TeacherAssignment[]
  attendance  TeacherAttendance[]
  quizzes     Quiz[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("teachers")
}

/// Teacher assignment (Module 4): one independent row per
/// Teacher × AcademicYear × Class × Section × Subject.
///
/// Valid examples (all allowed for the same teacher):
/// - Grade 7 / Section A / Mathematics
/// - Grade 7 / Section A / Physics
/// - Grade 7 / Section B / Mathematics
/// - Grade 8 / Section A / Mathematics
///
/// sectionId = null means "all sections" of the class.
/// Exact duplicates only: same teacher + year + class + section + subject.
/// Uniqueness is enforced by index teacher_assignments_exact_dup_key
/// (COALESCE(sectionId,'') so NULL sections are included).
model TeacherAssignment {
  id             String   @id @default(cuid())
  schoolId       String
  teacherId      String
  academicYearId String
  classId        String
  sectionId      String?
  subjectId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
  @@index([schoolId, teacherId, academicYearId])
  @@index([schoolId, classId, sectionId, subjectId, academicYearId])
  @@map("teacher_assignments")
}

/// Daily student attendance (Module 5). One record per student per day.
model StudentAttendance {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  classId        String
  sectionId      String?
  academicYearId String
  date           DateTime         @db.Date
  status         AttendanceStatus
  markedByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, date])
  @@index([schoolId, date])
  @@index([classId, sectionId, date])
  @@map("student_attendance")
}

/// Daily teacher attendance (Module 6). Shift-scoped. One record per day.
model TeacherAttendance {
  id             String           @id @default(cuid())
  schoolId       String
  teacherId      String
  shift          Shift
  date           DateTime         @db.Date
  status         AttendanceStatus
  markedByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, date])
  @@index([schoolId, date])
  @@map("teacher_attendance")
}

/// Monthly fee charge per student (Module 7). One per student per year+month.
model FeeCharge {
  id             String    @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String?
  year           Int
  month          Int
  amount         Int
  paidAmount     Int       @default(0)
  status         FeeStatus @default(UNPAID)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, year, month])
  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@map("fee_charges")
}

/// One-time academic year fee activation per school year (Academic Year billing mode).
model AcademicYearFeeSetup {
  id                String   @id @default(cuid())
  schoolId          String
  academicYearId    String
  academicMonths    Int
  billingStartMonth Int
  billingEndMonth   Int
  monthlyFee        Int?
  totalAnnualFee    Int
  activatedAt       DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId])
  @@index([schoolId])
  @@map("academic_year_fee_setups")
}

/// A fee payment with a receipt (Module 7).
model Payment {
  id                String      @id @default(cuid())
  schoolId          String
  studentId         String
  receiptNumber     String
  type              PaymentType
  amount            Int
  method            String?
  collectedByUserId String?
  note              String?
  paidAt            DateTime    @default(now())
  createdAt         DateTime    @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, receiptNumber])
  @@index([schoolId])
  @@index([studentId])
  @@map("payments")
}

/// Salary record for an employee (Module 8).
model Salary {
  id           String       @id @default(cuid())
  schoolId     String
  teacherId    String?
  employeeName String
  position     String?
  amount       Int
  year         Int
  month        Int
  status       SalaryStatus @default(PENDING)
  paidAt       DateTime?
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([schoolId])
  @@map("salaries")
}

/// Expense category (Module 9).
model ExpenseCategory {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("expense_categories")
}

/// Operational expense (Module 9).
model Expense {
  id               String   @id @default(cuid())
  schoolId         String
  categoryId       String?
  title            String
  amount           Int
  method           String?
  note             String?
  recordedByUserId String?
  spentAt          DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@map("expenses")
}

// ── Examinations (Module 11) ────────────────────────────────────────────────

model ExamGroup {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams        Exam[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@map("exam_groups")
}

model Exam {
  id              String     @id @default(cuid())
  schoolId        String
  academicYearId  String
  examGroupId     String?
  name            String
  examType        ExamType   @default(TEACHER_ASSESSMENT)
  term            String
  maxMarks        Int        @default(100)
  weightPercent   Int        @default(100)
  startDate       DateTime   @db.Date
  endDate         DateTime   @db.Date
  status          ExamStatus @default(DRAFT)
  classId         String
  sectionId       String?
  createdByUserId String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  academicYear AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examGroup    ExamGroup?    @relation(fields: [examGroupId], references: [id], onDelete: SetNull)
  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjects     ExamSubject[]
  marks        ExamMark[]
  blocked      BlockedStudent[]

  @@index([schoolId])
  @@index([classId, sectionId])
  @@map("exams")
}

model ExamSubject {
  id               String           @id @default(cuid())
  schoolId         String
  examId           String
  subjectId        String
  teacherId        String?
  submissionStatus SubmissionStatus @default(PENDING)
  submittedAt      DateTime?
  createdAt        DateTime         @default(now())

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, examId, subjectId])
  @@index([examId])
  @@map("exam_subjects")
}

model ExamMark {
  id              String    @id @default(cuid())
  schoolId        String
  examId          String
  studentId       String
  subjectId       String
  marks           Int?
  enteredByUserId String?
  enteredAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@map("exam_marks")
}

model BlockedStudent {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  examId          String?
  academicYearId  String
  reason          String
  blockedByUserId String?
  blockedAt       DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam?   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@map("blocked_students")
}

// ── Promotions (Module 13) ──────────────────────────────────────────────────

model PromotionRecord {
  id               String         @id @default(cuid())
  schoolId         String
  studentId        String
  academicYearId   String
  type             PromotionType
  fromClassId      String
  fromSectionId    String?
  toClassId        String?
  toSectionId      String?
  graduated        Boolean        @default(false)
  promotedAt       DateTime       @default(now())
  promotedByUserId String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@map("promotion_records")
}

// ── Quiz (Module 12) ──────────────────────────────────────────────────────

model Quiz {
  id                     String     @id @default(cuid())
  schoolId               String
  academicYearId         String
  classId                String
  sectionId              String?
  subjectId              String?
  teacherId              String
  title                  String
  code                   String
  description            String?
  status                 QuizStatus @default(DRAFT)
  timeLimitMin           Int?
  maxAttempts            Int        @default(1)
  passingMarks           Int?
  startAt                DateTime?
  endAt                  DateTime?
  shuffleQuestions       Boolean    @default(false)
  shuffleAnswers         Boolean    @default(false)
  showResultsImmediately Boolean    @default(true)
  instructions           String?
  preventMinimize        Boolean    @default(false)
  disableCopyPaste       Boolean    @default(false)
  resetOnMinimize        Boolean    @default(false)
  publishedAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class        Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  section      Section?       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacher      Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([teacherId])
  @@map("quizzes")
}

model QuizQuestion {
  id                  String   @id @default(cuid())
  schoolId            String
  quizId              String
  question            String
  // MCQ | DIRECT | MATCH | FILL_BLANK (legacy: ESSAY | SHORT_ANSWER)
  questionType        String   @default("MCQ")
  options             Json
  correctAnswer       String   @default("")
  // EXACT (string match) | AI_CONCEPT (OpenAI-scored) — only honoured for DIRECT.
  gradingMode         String   @default("EXACT")
  // MATCH: [{ left, right }] correct pairs. FILL_BLANK: ["ans1","ans2",...] per blank.
  pairs               Json?
  blanks              Json?
  marks               Int      @default(1)
  requiresManualGrade Boolean  @default(false)
  orderIndex          Int      @default(0)
  createdAt           DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String            @id @default(cuid())
  schoolId    String
  quizId      String
  studentId   String
  status      QuizAttemptStatus @default(IN_PROGRESS)
  score       Int?
  percentage  Float?
  result      String?
  startedAt   DateTime          @default(now())
  submittedAt DateTime?

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String  @id @default(cuid())
  schoolId   String
  attemptId  String
  questionId String
  answer     String?
  isCorrect  Boolean @default(false)
  marks      Int     @default(0)
  // 0-100 similarity for AI-graded DIRECT answers; null for exact-graded types.
  awardedPercentage Float?
  aiFeedback        String?

  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([schoolId, attemptId, questionId])
  @@map("quiz_answers")
}

// ── Announcements & Notifications (Module 17) ───────────────────────────────

model Announcement {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  body            String
  audience        String   @default("ALL")
  publishedAt     DateTime @default(now())
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([schoolId])
  @@map("announcements")
}

model Notification {
  id        String    @id @default(cuid())
  schoolId  String
  userId    String?
  parentId  String?
  title     String
  body      String
  type      String    @default("INFO")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([parentId])
  @@map("notifications")
}

// ── Backup & Import jobs (Modules 19, 22) ─────────────────────────────────

model BackupJob {
  id          String       @id @default(cuid())
  schoolId    String
  status      JobStatus    @default(PENDING)
  storageKey  String?
  sizeBytes   Int?
  error       String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([schoolId])
  @@map("backup_jobs")
}

model ImportJob {
  id          String    @id @default(cuid())
  schoolId    String
  type        String
  status      JobStatus @default(PENDING)
  fileKey     String?
  summary     Json?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([schoolId])
  @@map("import_jobs")
}

/// Library (Module 16): book catalogue. Managed by ADMINISTRATOR + LIBRARIAN.
model Book {
  id              String       @id @default(cuid())
  schoolId        String
  title           String
  author          String?
  isbn            String?
  category        String?
  totalCopies     Int          @default(1)
  availableCopies Int          @default(1)
  status          EntityStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  loans BookLoan[]

  @@index([schoolId])
  @@map("books")
}

/// A book issued to a student; returned when the copy comes back.
model BookLoan {
  id             String     @id @default(cuid())
  schoolId       String
  bookId         String
  studentId      String
  issuedAt       DateTime   @default(now())
  dueDate        DateTime   @db.Date
  returnedAt     DateTime?
  status         LoanStatus @default(ISSUED)
  issuedByUserId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  book    Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([bookId])
  @@index([studentId])
  @@map("book_loans")
}

