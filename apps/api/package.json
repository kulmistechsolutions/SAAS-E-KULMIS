{
  "name": "@ekulmis/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "echo \"(api) ESLint configured in Phase 1\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "prisma:generate": "node prisma/with-env.cjs generate",
    "prisma:migrate": "node prisma/with-env.cjs migrate dev",
    "prisma:deploy": "node prisma/with-env.cjs migrate deploy",
    "prisma:studio": "node prisma/with-env.cjs studio"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@ekulmis/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.5",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.5",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.2.1",
    "@supabase/supabase-js": "^2.110.1",
    "bullmq": "^5.79.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "minio": "^8.0.7",
    "nestjs-pino": "^4.3.0",
    "pdfkit": "^0.19.1",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.6",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
